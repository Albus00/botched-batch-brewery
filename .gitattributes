############################################################
# Default behavior
############################################################

* text=auto

############################################################
# C# files - force LF for cross-platform sanity
############################################################

*.cs text eol=lf

############################################################
# Godot text formats
############################################################

*.gd text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.shader text eol=lf
*.cfg text eol=lf

############################################################
# Binary assets
############################################################

*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.wav binary
*.ogg binary
*.mp3 binary
*.glb binary
*.fbx binary
*.ttf binary
*.otf binary

############################################################
# Prevent large diff noise
############################################################

*.tscn diff
*.tres diff